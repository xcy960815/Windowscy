<Window
    x:Class="ClipLoom.SettingsPoC.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="{StaticResource ClipLoomShellBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="20,20,20,12"
            Padding="28,24"
            Background="{StaticResource ClipLoomCardBrush}"
            BorderBrush="{StaticResource ClipLoomStrokeBrush}"
            BorderThickness="1"
            CornerRadius="24">
            <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="72"
                    Height="72"
                    Background="{StaticResource ClipLoomAccentBrush}"
                    CornerRadius="20">
                    <Viewbox Stretch="Uniform">
                        <TextBlock
                            Foreground="White"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="CL" />
                    </Viewbox>
                </Border>

                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock
                        x:Name="WindowTitleText"
                        Foreground="{StaticResource ClipLoomTextBrush}"
                        FontSize="34"
                        FontWeight="SemiBold"
                        Text="ClipLoom Settings PoC" />
                    <TextBlock
                        x:Name="WindowSubtitleText"
                        MaxWidth="920"
                        Foreground="{StaticResource ClipLoomMutedBrush}"
                        FontSize="16"
                        TextWrapping="Wrap"
                        Text="A WinUI 3 shell for testing a more modern settings experience before replacing the current Win32 page." />
                </StackPanel>
            </Grid>
        </Border>

        <Grid
            Grid.Row="1"
            Margin="20,0,20,12"
            ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="12"
                Background="{StaticResource ClipLoomCardBrush}"
                BorderBrush="{StaticResource ClipLoomStrokeBrush}"
                BorderThickness="1"
                CornerRadius="24">
                <NavigationView
                    x:Name="RootNavigationView"
                    IsBackButtonVisible="Collapsed"
                    IsPaneToggleButtonVisible="False"
                    IsSettingsVisible="False"
                    PaneDisplayMode="Left"
                    SelectionChanged="NavigationViewSelectionChanged">
                    <NavigationView.Header>
                        <StackPanel Margin="8,4,8,12" Spacing="6">
                            <TextBlock
                                Foreground="{StaticResource ClipLoomMutedBrush}"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="WINUI 3 SETTINGS" />
                            <TextBlock
                                Foreground="{StaticResource ClipLoomTextBrush}"
                                FontSize="28"
                                FontWeight="SemiBold"
                                Text="Settings Center" />
                            <TextBlock
                                Foreground="{StaticResource ClipLoomMutedBrush}"
                                FontSize="14"
                                Text="Replace the current owner-draw Win32 shell with native Fluent controls first." />
                        </StackPanel>
                    </NavigationView.Header>
                    <NavigationView.MenuItems>
                        <NavigationViewItem
                            Content="General"
                            Tag="general">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Home" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                        <NavigationViewItem
                            Content="Appearance"
                            Tag="appearance">
                            <NavigationViewItem.Icon>
                                <SymbolIcon Symbol="Edit" />
                            </NavigationViewItem.Icon>
                        </NavigationViewItem>
                    </NavigationView.MenuItems>
                </NavigationView>
            </Border>

            <Grid Grid.Column="1" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Padding="22,18"
                    Background="{StaticResource ClipLoomCardBrush}"
                    BorderBrush="{StaticResource ClipLoomStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="24">
                    <StackPanel Spacing="6">
                        <TextBlock
                            x:Name="CurrentPageTagText"
                            Foreground="{StaticResource ClipLoomTextBrush}"
                            FontSize="28"
                            FontWeight="SemiBold"
                            Text="General" />
                        <TextBlock
                            x:Name="CurrentPageSummaryText"
                            Foreground="{StaticResource ClipLoomMutedBrush}"
                            FontSize="14"
                            Text="Validate the opening trigger, startup, capture and apply/save workflow in Fluent controls." />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Background="{StaticResource ClipLoomCardBrush}"
                    BorderBrush="{StaticResource ClipLoomStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="24">
                    <Frame x:Name="ContentFrame" />
                </Border>
            </Grid>
        </Grid>

        <Border
            Grid.Row="2"
            Margin="20,0,20,20"
            Padding="20,16"
            Background="{StaticResource ClipLoomCardBrush}"
            BorderBrush="{StaticResource ClipLoomStrokeBrush}"
            BorderThickness="1"
            CornerRadius="24">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="2">
                    <TextBlock
                        Text="Prototype Status"
                        Foreground="{StaticResource ClipLoomMutedBrush}"
                        FontSize="12"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="ActionStatusText"
                        Text="Loaded demo snapshot. Apply/Save are wired as placeholders for the bridge step."
                        Foreground="{StaticResource ClipLoomTextBrush}"
                        FontSize="14" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Margin="0,0,12,0"
                    Click="SaveButtonClick"
                    Content="Save"
                    Style="{StaticResource AccentButtonStyle}" />
                <Button
                    Grid.Column="2"
                    Margin="0,0,12,0"
                    Click="ApplyButtonClick"
                    Content="Apply" />
                <Button
                    Grid.Column="3"
                    Click="CloseButtonClick"
                    Content="Close" />
            </Grid>
        </Border>
    </Grid>
</Window>
