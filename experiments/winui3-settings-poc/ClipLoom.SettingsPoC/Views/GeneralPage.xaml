<Page
    x:Class="ClipLoom.SettingsPoC.Views.GeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Spacing="16">
            <Border
                Padding="24"
                Background="{StaticResource ClipLoomCardBrush}"
                BorderBrush="{StaticResource ClipLoomStrokeBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <StackPanel Spacing="18">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Foreground="{StaticResource ClipLoomTextBrush}"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="Open ClipLoom" />
                        <TextBlock
                            Foreground="{StaticResource ClipLoomMutedBrush}"
                            FontSize="14"
                            Text="Choose how the clipboard history window should open." />
                    </StackPanel>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="14">
                            <ToggleSwitch
                                x:Name="DoubleClickToggle"
                                Header="Enable double-click modifier trigger"
                                IsOn="True"
                                OffContent="Off"
                                OnContent="On" />
                            <ComboBox x:Name="ModifierKeyCombo" Header="Modifier key">
                                <x:String>Ctrl</x:String>
                                <x:String>Alt</x:String>
                                <x:String>Shift</x:String>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="14">
                            <TextBlock
                                Foreground="{StaticResource ClipLoomMutedBrush}"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="HOTKEY" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <CheckBox Content="Ctrl" />
                                <CheckBox Content="Alt" />
                                <CheckBox Content="Shift" IsChecked="True" />
                                <CheckBox Content="Win" />
                            </StackPanel>
                            <ComboBox x:Name="HotKeyCombo" Header="Key">
                                <x:String>C</x:String>
                                <x:String>V</x:String>
                                <x:String>Space</x:String>
                                <x:String>F1</x:String>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border
                Padding="24"
                Background="{StaticResource ClipLoomCardBrush}"
                BorderBrush="{StaticResource ClipLoomStrokeBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <StackPanel Spacing="18">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Foreground="{StaticResource ClipLoomTextBrush}"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="Behavior" />
                        <TextBlock
                            Foreground="{StaticResource ClipLoomMutedBrush}"
                            FontSize="14"
                            Text="These switches should eventually map 1:1 to SettingsSnapshot." />
                    </StackPanel>

                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="14">
                            <ToggleSwitch x:Name="CaptureEnabledToggle" Header="Capture clipboard changes" IsOn="True" />
                            <ToggleSwitch x:Name="AutoPasteToggle" Header="Auto paste after selecting an item" />
                            <ToggleSwitch x:Name="PlainTextToggle" Header="Paste as plain text" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="14">
                            <ToggleSwitch x:Name="StartupToggle" Header="Start ClipLoom on sign in" />
                            <ToggleSwitch x:Name="StartupGuideToggle" Header="Show startup guide" />
                            <TextBlock
                                Foreground="{StaticResource ClipLoomMutedBrush}"
                                FontSize="13"
                                Text="This page intentionally uses stock WinUI controls only. No owner-draw workaround should be needed here." />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border
                Padding="24"
                Background="#FFF8FAFD"
                BorderBrush="{StaticResource ClipLoomStrokeBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <TextBlock
                    Foreground="{StaticResource ClipLoomMutedBrush}"
                    FontSize="13"
                    TextWrapping="Wrap"
                    Text="Next integration step: hydrate these controls from SettingsSnapshot and export edits back through ApplySettingsSnapshot(...) instead of reading individual Win32 HWND values." />
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
