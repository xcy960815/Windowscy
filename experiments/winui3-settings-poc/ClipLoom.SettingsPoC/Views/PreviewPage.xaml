<Page
    x:Class="ClipLoom.SettingsPoC.Views.PreviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" Spacing="16">
            <Border
                Padding="24"
                Background="{StaticResource ClipLoomCardBrush}"
                BorderBrush="{StaticResource ClipLoomStrokeBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <AutoSuggestBox
                        PlaceholderText="Search clipboard history"
                        QueryIcon="Find" />
                    <ComboBox
                        Grid.Column="1"
                        Width="160"
                        SelectedIndex="0">
                        <x:String>Mixed</x:String>
                        <x:String>Exact</x:String>
                        <x:String>Fuzzy</x:String>
                        <x:String>Regexp</x:String>
                    </ComboBox>
                    <ToggleSwitch
                        Grid.Column="2"
                        Margin="8,0,0,0"
                        Header="Preview"
                        IsOn="True" />
                </Grid>
            </Border>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Padding="16"
                    Background="{StaticResource ClipLoomCardBrush}"
                    BorderBrush="{StaticResource ClipLoomStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                    <StackPanel Spacing="14">
                        <TextBlock
                            Foreground="{StaticResource ClipLoomTextBrush}"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Text="History Items" />
                        <TextBlock
                            Foreground="{StaticResource ClipLoomMutedBrush}"
                            FontSize="13"
                            Text="A WinUI list can replace the owner-draw Win32 listbox and subtitle painting." />

                        <ListView SelectionMode="Single" SelectedIndex="0">
                            <ListViewItem Padding="0">
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="16"
                                    Background="#FFEAF1FF"
                                    BorderBrush="#FFB0C7F7"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                    <StackPanel Spacing="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Foreground="{StaticResource ClipLoomTextBrush}"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="Deploy checklist for Friday build" />
                                            <InfoBadge
                                                Grid.Column="1"
                                                Value="1" />
                                        </Grid>
                                        <TextBlock
                                            Foreground="{StaticResource ClipLoomMutedBrush}"
                                            FontSize="13"
                                            Text="Code.exe / Text, HTML / Copies 3" />
                                    </StackPanel>
                                </Border>
                            </ListViewItem>

                            <ListViewItem Padding="0">
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="16"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource ClipLoomStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                    <StackPanel Spacing="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Foreground="{StaticResource ClipLoomTextBrush}"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="ssh user@server && tail -f /var/log/app.log" />
                                            <FontIcon
                                                Grid.Column="1"
                                                Glyph="&#xE718;"
                                                Foreground="#FFB36B00" />
                                        </Grid>
                                        <TextBlock
                                            Foreground="{StaticResource ClipLoomMutedBrush}"
                                            FontSize="13"
                                            Text="WindowsTerminal.exe / Text / Pinned" />
                                    </StackPanel>
                                </Border>
                            </ListViewItem>

                            <ListViewItem Padding="0">
                                <Border
                                    Padding="16"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource ClipLoomStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                    <StackPanel Spacing="8">
                                        <TextBlock
                                            Foreground="{StaticResource ClipLoomTextBrush}"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="Design feedback summary from user interviews" />
                                        <TextBlock
                                            Foreground="{StaticResource ClipLoomMutedBrush}"
                                            FontSize="13"
                                            Text="Notion.exe / Text / Copies 2" />
                                    </StackPanel>
                                </Border>
                            </ListViewItem>
                        </ListView>
                    </StackPanel>
                </Border>

                <StackPanel
                    Grid.Column="1"
                    Spacing="16">
                    <Border
                        Padding="20"
                        Background="{StaticResource ClipLoomCardBrush}"
                        BorderBrush="{StaticResource ClipLoomStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="20">
                        <StackPanel Spacing="10">
                            <TextBlock
                                Foreground="{StaticResource ClipLoomTextBrush}"
                                FontSize="24"
                                FontWeight="SemiBold"
                                Text="Preview" />
                            <TextBlock
                                Foreground="{StaticResource ClipLoomMutedBrush}"
                                FontSize="14"
                                Text="This panel should replace the current read-only Win32 edit control." />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <InfoBadge Value="Text" />
                                <InfoBadge Value="HTML" />
                                <InfoBadge Value="3x" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border
                        Padding="20"
                        Background="{StaticResource ClipLoomCardBrush}"
                        BorderBrush="{StaticResource ClipLoomStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="20">
                        <StackPanel Spacing="12">
                            <TextBlock
                                Foreground="{StaticResource ClipLoomMutedBrush}"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Text="CONTENT" />
                            <TextBlock
                                Foreground="{StaticResource ClipLoomTextBrush}"
                                FontSize="16"
                                TextWrapping="Wrap"
                                Text="Deploy checklist for Friday build&#10;&#10;- Verify the new settings shell opens with the intended shortcut&#10;- Confirm clipboard capture remains enabled&#10;- Review release notes before packaging" />
                        </StackPanel>
                    </Border>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Padding="18"
                            Background="{StaticResource ClipLoomCardBrush}"
                            BorderBrush="{StaticResource ClipLoomStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="20">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    Foreground="{StaticResource ClipLoomMutedBrush}"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="SOURCE" />
                                <TextBlock
                                    Foreground="{StaticResource ClipLoomTextBrush}"
                                    FontSize="15"
                                    Text="Code.exe" />
                                <TextBlock
                                    Foreground="{StaticResource ClipLoomMutedBrush}"
                                    FontSize="13"
                                    Text="Captured from an active editor session." />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Padding="18"
                            Background="{StaticResource ClipLoomCardBrush}"
                            BorderBrush="{StaticResource ClipLoomStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="20">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    Foreground="{StaticResource ClipLoomMutedBrush}"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="ACTIONS" />
                                <Button Content="Paste Selected Item" Style="{StaticResource AccentButtonStyle}" />
                                <Button Content="Pin Item" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
